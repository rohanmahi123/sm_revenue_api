# Copy this to .env and edit as needed.

# SQLite (default — zero config, great for dev / single-server):
DATABASE_URL=sqlite:///./sm_revenue.db

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/sm_revenue

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/sm_revenue

DB_ECHO=false                  # set to true to log all SQL statements

MODEL_STORE_DIR=model_store    # directory on disk where .pkl files are saved

DEBUG=false
